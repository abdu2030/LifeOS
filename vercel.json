{
  "buildCommand": "npm run build",
  "framework": "vite",
  "headers": [
    {
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ],
      "source": "/sw.js"
    },
    {
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "source": "/assets/(.*)"
    }
  ],
  "outputDirectory": "dist",
  "rewrites": [
    {
      "destination": "/index.html",
      "source": "/(.*)"
    }
  ]
}
