VITE_SUPABASE_URL=https://your-project.supabase.co
# Use the anon public key or publishable key from the same Supabase project as the URL.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional compatibility names if credentials come from a Next.js template.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
